# Minimal dockerignore - only exclude what's absolutely necessary

# Version control (but NOT python_fit_tool/.git)
.git
!src/backend/python_fit_tool/.git

# Virtual environments (must not be copied)
**/.venv
**/venv
**/ENV
**/env

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd

# Node modules (for app and landing)
**/node_modules

# IDE
.vscode
.idea
**/*.swp
**/*.swo

# Local env files
.env
.env.local
.env.*.local

# Logs
**/*.log

# OS files
.DS_Store
**/.DS_Store

# Other
.cache
tmp
temp

# Exclude app and landing directories (only backend needed for backend Docker build)
src/app
src/landing
src/supabase
docs
.github
