ENVIRONMENT= # must be set to "production" or "staging" or "development"

## Openrouter
PRIVATE_OPENROUTER_API_KEY=


## Supabase
PUBLIC_SUPABASE_URL=


CHAT_HISTORY_DB_CONN_STRING=
ACTIVITY_DB_CONN_STRING=



PUBLIC_SUPABASE_KEY=
PRIVATE_SUPABASE_KEY=

# For key encryption use the following command to generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=""




## Own variables
BACKEND_BASE_URL=       # "http://localhost:8000"
FRONTEND_URLS=          # "http://localhost:8081"


## Redis
# Redis connection URL for temporary data storage (PKCE verifiers, caching)
# Format: redis://[host]:[port]/[database]
# Docker Compose default: redis://redis:6379/0
# Local development: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0


#################
#Optional variables for third-party integrations (set if you want to use these features)
#################


## Wahoo
WAHOO_CLIENT_ID=
WAHOO_CLIENT_SECRET=
# Webhook URL that Wahoo will call when workouts are created/updated
# Example: https://api.trainaa.com/v1/wahoo/webhook/callback
WAHOO_WEBHOOK_CALLBACK_URL=
# Secret token to verify webhook requests from Wahoo (configure in Wahoo developer portal)
WAHOO_WEBHOOK_VERIFY_TOKEN=

## Garmin
GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

## Strava
PUBLIC_STRAVA_CLIENT_ID=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_CALLBACK_URL=
STRAVA_WEBHOOK_VERIFY_TOKEN=






## Langfuse
LANGFUSE_SECRET_API_KEY=
LANGFUSE_PUBLIC_API_KEY=
LANGFUSE_HOST=


## RevenueCat
# V2 API key (requires "read" permission for customers)
REVENUECAT_API_KEY=""
# Project ID from RevenueCat dashboard (required for V2 API)
REVENUECAT_PROJECT_ID=""
# Optional webhook signature verification token
REVENUECAT_WEBHOOK_SECRET=""

## Stripe
# Stripe secret key for creating checkout sessions and managing subscriptions
STRIPE_SECRET_KEY=""
# Stripe product ID for PRO subscription
STRIPE_PRODUCT_ID=""
# Stripe price ID for PRO subscription
STRIPE_PRICE_ID=""
# Stripe Customer Portal URL (static URL for subscription management)
STRIPE_CUSTOMER_PORTAL_URL=""

